{
  "name": "xkeen-ui-frontend-build",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.8",
  "scripts": {
    "frontend:vendor": "python scripts/sync_frontend_vendor.py",
    "frontend:build": "python scripts/sync_frontend_vendor.py && vite build --config vite.config.mjs && python scripts/sync_frontend_build_manifest.py",
    "frontend:verify:static": "node scripts/verify_frontend_build.mjs",
    "frontend:verify": "npm run frontend:build && npm run frontend:verify:static",
    "build:frontend": "npm run frontend:build",
    "verify:frontend": "npm run frontend:verify",
    "archive:user": "python scripts/build_user_archive.py",
    "archive:user:skip-build": "python scripts/build_user_archive.py --skip-frontend-build",
    "e2e:install": "playwright install chromium",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:smoke": "playwright test e2e/smoke.spec.mjs",
    "e2e:smoke:headed": "playwright test e2e/smoke.spec.mjs --headed"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@lezer/common": "^1.5.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/json": "^1.0.3",
    "@lezer/lr": "^1.4.8",
    "@lezer/yaml": "^1.0.4",
    "@marijn/find-cluster-break": "^1.0.2",
    "@playwright/test": "^1.59.1",
    "@replit/codemirror-indentation-markers": "^6.5.3",
    "codemirror": "^6.0.2",
    "crelt": "^1.0.6",
    "js-yaml": "^4.1.1",
    "jsonc-parser": "^3.3.1",
    "prettier": "^3.8.1",
    "style-mod": "^4.1.3",
    "vite": "8.0.3",
    "w3c-keyname": "^2.2.8"
  }
}
