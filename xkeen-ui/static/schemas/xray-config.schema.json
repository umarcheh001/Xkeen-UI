{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Xray-core Config",
  "description": "JSON Schema for Xray-core configuration (v1.8+). Covers inbounds, outbounds, routing, DNS, transport, policy, stats, observatory, reverse, fakedns, metrics, burstObservatory.",
  "type": "object",
  "properties": {
    "log": {
      "description": "Настройки логирования",
      "type": "object",
      "properties": {
        "access": { "type": "string", "description": "Путь к файлу лога доступа. Пусто — stdout, 'none' — отключить" },
        "error": { "type": "string", "description": "Путь к файлу лога ошибок. Пусто — stderr" },
        "loglevel": {
          "type": "string",
          "enum": ["debug", "info", "warning", "error", "none"],
          "default": "warning",
          "description": "Уровень логирования"
        },
        "dnsLog": { "type": "boolean", "default": false, "description": "Логировать DNS-запросы" }
      },
      "additionalProperties": false
    },

    "api": {
      "description": "gRPC API для управления Xray",
      "type": "object",
      "properties": {
        "tag": { "type": "string", "description": "Тег для inbound (обычно 'api')" },
        "listen": { "type": "string", "description": "Адрес gRPC (например '127.0.0.1:10085')" },
        "services": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["HandlerService", "LoggerService", "StatsService", "RoutingService", "ReflectionService"]
          },
          "description": "Список gRPC-сервисов"
        }
      },
      "additionalProperties": false
    },

    "dns": {
      "description": "Встроенный DNS-сервер",
      "type": "object",
      "properties": {
        "hosts": {
          "type": "object",
          "description": "Статические DNS-записи (домен → IP или домен)",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "array", "items": { "type": "string" } }
            ]
          }
        },
        "servers": {
          "type": "array",
          "description": "Список DNS-серверов",
          "items": {
            "oneOf": [
              { "type": "string", "description": "DNS-адрес (например '8.8.8.8', 'https+local://dns.google/dns-query', 'localhost')" },
              {
                "type": "object",
                "properties": {
                  "address": { "type": "string", "description": "DNS-адрес" },
                  "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 53 },
                  "clientIp": { "type": "string", "description": "IP-адрес клиента для EDNS" },
                  "skipFallback": { "type": "boolean", "default": false },
                  "domains": { "type": "array", "items": { "type": "string" }, "description": "Домены для этого сервера" },
                  "expectIPs": { "type": "array", "items": { "type": "string" }, "description": "Ожидаемые IP-диапазоны" },
                  "queryStrategy": { "type": "string", "enum": ["UseIP", "UseIPv4", "UseIPv6"] }
                },
                "required": ["address"]
              }
            ]
          }
        },
        "clientIp": { "type": "string", "description": "IP-адрес клиента для EDNS" },
        "queryStrategy": {
          "type": "string",
          "enum": ["UseIP", "UseIPv4", "UseIPv6"],
          "default": "UseIP",
          "description": "Стратегия DNS-запросов"
        },
        "disableCache": { "type": "boolean", "default": false },
        "disableFallback": { "type": "boolean", "default": false },
        "disableFallbackIfMatch": { "type": "boolean", "default": false },
        "tag": { "type": "string", "description": "Тег для маршрутизации DNS-трафика" }
      },
      "additionalProperties": false
    },

    "routing": {
      "description": "Правила маршрутизации трафика",
      "type": "object",
      "properties": {
        "domainStrategy": {
          "type": "string",
          "enum": ["AsIs", "IPIfNonMatch", "IPOnDemand"],
          "default": "AsIs",
          "description": "Стратегия сопоставления доменов"
        },
        "domainMatcher": {
          "type": "string",
          "enum": ["hybrid", "linear"],
          "default": "hybrid",
          "description": "Алгоритм сопоставления доменов"
        },
        "rules": {
          "type": "array",
          "description": "Массив правил маршрутизации",
          "items": { "$ref": "#/definitions/routingRule" }
        },
        "balancers": {
          "type": "array",
          "description": "Балансировщики нагрузки",
          "items": { "$ref": "#/definitions/balancer" }
        }
      },
      "additionalProperties": false
    },

    "inbounds": {
      "description": "Входящие подключения",
      "type": "array",
      "items": { "$ref": "#/definitions/inbound" }
    },

    "outbounds": {
      "description": "Исходящие подключения",
      "type": "array",
      "items": { "$ref": "#/definitions/outbound" }
    },

    "transport": {
      "description": "Глобальные настройки транспорта (устаревшее, используйте streamSettings в inbound/outbound)",
      "type": "object"
    },

    "policy": {
      "description": "Политики (таймауты, статистика)",
      "type": "object",
      "properties": {
        "levels": {
          "type": "object",
          "description": "Политики по уровням пользователей",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "handshake": { "type": "integer", "default": 4 },
              "connIdle": { "type": "integer", "default": 300 },
              "uplinkOnly": { "type": "integer", "default": 2 },
              "downlinkOnly": { "type": "integer", "default": 5 },
              "statsUserUplink": { "type": "boolean", "default": false },
              "statsUserDownlink": { "type": "boolean", "default": false },
              "bufferSize": { "type": "integer", "default": 512, "description": "Буфер на соединение (КБ). 0 — без буфера, -1 — без лимита" }
            }
          }
        },
        "system": {
          "type": "object",
          "properties": {
            "statsInboundUplink": { "type": "boolean", "default": false },
            "statsInboundDownlink": { "type": "boolean", "default": false },
            "statsOutboundUplink": { "type": "boolean", "default": false },
            "statsOutboundDownlink": { "type": "boolean", "default": false },
            "overrideAccessLogDest": { "type": "boolean", "default": false }
          }
        }
      },
      "additionalProperties": false
    },

    "stats": {
      "description": "Включить сбор статистики (пустой объект для активации)",
      "type": "object",
      "properties": {},
      "additionalProperties": false
    },

    "reverse": {
      "description": "Обратный прокси (reverse proxy)",
      "type": "object",
      "properties": {
        "bridges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tag": { "type": "string" },
              "domain": { "type": "string" }
            },
            "required": ["tag", "domain"]
          }
        },
        "portals": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tag": { "type": "string" },
              "domain": { "type": "string" }
            },
            "required": ["tag", "domain"]
          }
        }
      },
      "additionalProperties": false
    },

    "fakedns": {
      "description": "FakeDNS для sniffing",
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "ipPool": { "type": "string", "default": "198.18.0.0/15", "description": "CIDR-диапазон для фейковых IP" },
            "poolSize": { "type": "integer", "default": 65535 }
          }
        },
        {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ipPool": { "type": "string" },
              "poolSize": { "type": "integer" }
            }
          }
        }
      ]
    },

    "observatory": {
      "description": "Мониторинг доступности outbound (для leastPing)",
      "type": "object",
      "properties": {
        "subjectSelector": { "type": "array", "items": { "type": "string", "examples": ["vless-reality", "proxy"] }, "description": "Теги/префиксы outbound для мониторинга" },
        "probeUrl": { "type": "string", "default": "https://www.google.com/generate_204" },
        "probeInterval": { "type": "string", "default": "10s", "description": "Интервал проверки (например '60s')" },
        "enableConcurrency": { "type": "boolean", "default": false, "description": "Параллельная проверка" }
      },
      "additionalProperties": false
    },

    "burstObservatory": {
      "description": "Альтернативный observatory с burst-проверкой",
      "type": "object",
      "properties": {
        "subjectSelector": { "type": "array", "items": { "type": "string", "examples": ["vless-reality", "proxy"] } },
        "pingConfig": {
          "type": "object",
          "properties": {
            "destination": { "type": "string" },
            "connectivity": { "type": "string" },
            "interval": { "type": "string" },
            "sampling": { "type": "integer" },
            "timeout": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    },

    "metrics": {
      "description": "Встроенный HTTP-сервер метрик (Prometheus-совместимый)",
      "type": "object",
      "properties": {
        "tag": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,

  "definitions": {
    "routingRule": {
      "type": "object",
      "description": "Правило маршрутизации",
      "properties": {
        "type": { "type": "string", "enum": ["field"], "default": "field" },
        "domain": { "type": "array", "items": { "type": "string" }, "description": "Домены (regexp:, domain:, full:, geosite:, ext:)" },
        "ip": { "type": "array", "items": { "type": "string" }, "description": "IP/CIDR (geoip:, ext:)" },
        "port": { "type": ["string", "integer"], "description": "Порт или диапазон (например '53', '1024-65535', '80,443')" },
        "sourcePort": { "type": ["string", "integer"] },
        "network": { "type": "string", "enum": ["tcp", "udp", "tcp,udp"], "description": "Тип сети" },
        "source": { "type": "array", "items": { "type": "string" }, "description": "IP-адреса источника" },
        "user": { "type": "array", "items": { "type": "string" }, "description": "Email-адреса пользователей" },
        "inboundTag": { "type": "array", "items": { "type": "string", "examples": ["redirect", "tproxy"] }, "description": "Теги inbound" },
        "protocol": { "type": "array", "items": { "type": "string", "enum": ["http", "tls", "bittorrent"] } },
        "attrs": { "type": "object", "description": "Атрибуты для сопоставления" },
        "outboundTag": { "type": "string", "description": "Тег outbound для маршрутизации", "examples": ["direct", "block", "dns", "vless-reality"] },
        "balancerTag": { "type": "string", "description": "Тег балансировщика", "examples": ["proxy"] },
        "ruleTag": { "type": "string", "description": "Имя правила маршрутизации. Xkeen использует xk_auto_* для автоматически добавленных правил подписок.", "examples": ["xk_auto_leastPing"] },
        "domainMatcher": { "type": "string", "enum": ["hybrid", "linear"] }
      },
      "additionalProperties": false
    },

    "balancer": {
      "type": "object",
      "properties": {
        "tag": { "type": "string", "examples": ["proxy"] },
        "selector": { "type": "array", "items": { "type": "string", "examples": ["vless-reality", "direct", "block"] } },
        "fallbackTag": { "type": "string", "examples": ["direct", "block"] },
        "strategy": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["random", "leastPing", "roundRobin", "leastLoad"] }
          }
        }
      },
      "required": ["tag", "selector"]
    },

    "streamSettings": {
      "type": "object",
      "description": "Настройки транспорта",
      "properties": {
        "network": {
          "type": "string",
          "enum": ["tcp", "kcp", "ws", "http", "quic", "grpc", "httpupgrade", "splithttp", "xhttp"],
          "deprecatedValues": ["grpc"],
          "deprecationMessage": "Transport gRPC устарел в актуальных версиях Xray; по возможности используйте XHTTP (stream-up H2).",
          "default": "tcp"
        },
        "security": {
          "type": "string",
          "enum": ["none", "tls", "reality"],
          "default": "none"
        },
        "tlsSettings": {
          "type": "object",
          "properties": {
            "serverName": { "type": "string" },
            "alpn": { "type": "array", "items": { "type": "string" } },
            "allowInsecure": { "type": "boolean", "default": false },
            "fingerprint": {
              "type": "string",
              "enum": ["chrome", "firefox", "safari", "ios", "android", "edge", "360", "qq", "random", "randomized", ""]
            },
            "certificates": { "type": "array", "items": { "$ref": "#/definitions/certificate" } },
            "disableSystemRoot": { "type": "boolean", "default": false },
            "pinnedPeerCertificateChainSha256": { "type": "array", "items": { "type": "string" } },
            "minVersion": { "type": "string" },
            "maxVersion": { "type": "string" },
            "rejectUnknownSni": { "type": "boolean", "default": false }
          }
        },
        "realitySettings": {
          "type": "object",
          "properties": {
            "show": { "type": "boolean", "default": false },
            "dest": { "type": ["string", "integer"], "description": "Адрес назначения (например 'example.com:443')" },
            "xver": { "type": "integer", "enum": [0, 1, 2], "default": 0 },
            "serverNames": { "type": "array", "items": { "type": "string" } },
            "privateKey": { "type": "string" },
            "publicKey": { "type": "string" },
            "shortIds": { "type": "array", "items": { "type": "string" } },
            "fingerprint": { "type": "string" },
            "serverName": { "type": "string" },
            "spiderX": { "type": "string" },
            "minClientVer": { "type": "string" },
            "maxClientVer": { "type": "string" },
            "maxTimeDiff": { "type": "integer" }
          }
        },
        "tcpSettings": { "type": "object" },
        "kcpSettings": { "type": "object" },
        "wsSettings": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "host": { "type": "string" },
            "headers": { "type": "object", "additionalProperties": { "type": "string" } }
          }
        },
        "httpSettings": {
          "type": "object",
          "properties": {
            "host": { "type": "array", "items": { "type": "string" } },
            "path": { "type": "string" },
            "method": { "type": "string" },
            "headers": { "type": "object" }
          }
        },
        "grpcSettings": {
          "type": "object",
          "properties": {
            "serviceName": { "type": "string" },
            "multiMode": { "type": "boolean" },
            "authority": { "type": "string" }
          }
        },
        "httpupgradeSettings": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "host": { "type": "string" },
            "headers": { "type": "object", "additionalProperties": { "type": "string" } }
          }
        },
        "sockopt": {
          "type": "object",
          "properties": {
            "mark": { "type": "integer" },
            "tcpFastOpen": { "type": "boolean" },
            "tproxy": { "type": "string", "enum": ["redirect", "tproxy", "off"] },
            "domainStrategy": { "type": "string", "enum": ["AsIs", "UseIP", "UseIPv4", "UseIPv6"] },
            "dialerProxy": { "type": "string" },
            "tcpKeepAliveInterval": { "type": "integer" },
            "tcpKeepAliveIdle": { "type": "integer" },
            "tcpMptcp": { "type": "boolean" },
            "tcpNoDelay": { "type": "boolean" },
            "tcpcongestion": { "type": "string" },
            "interface": { "type": "string" },
            "v6only": { "type": "boolean" }
          }
        }
      }
    },

    "certificate": {
      "type": "object",
      "properties": {
        "usage": { "type": "string", "enum": ["encipherment", "verify", "issue", "verifyclient"] },
        "certificateFile": { "type": "string" },
        "keyFile": { "type": "string" },
        "certificate": { "type": "array", "items": { "type": "string" } },
        "key": { "type": "array", "items": { "type": "string" } },
        "ocspStapling": { "type": "integer" },
        "oneTimeLoading": { "type": "boolean" },
        "buildChain": { "type": "boolean" }
      }
    },

    "inbound": {
      "type": "object",
      "description": "Входящее подключение",
      "properties": {
        "listen": { "type": "string", "default": "0.0.0.0", "description": "Адрес прослушивания" },
        "port": {
          "type": ["integer", "string"],
          "description": "Порт или диапазон"
        },
        "protocol": {
          "type": "string",
          "enum": ["dokodemo-door", "http", "socks", "vmess", "vless", "trojan", "shadowsocks"],
          "description": "Протокол"
        },
        "settings": {
          "type": "object",
          "description": "Настройки протокола (зависят от protocol)"
        },
        "streamSettings": { "$ref": "#/definitions/streamSettings" },
        "tag": { "type": "string", "description": "Уникальный тег" },
        "sniffing": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "destOverride": {
              "type": "array",
              "items": { "type": "string", "enum": ["http", "tls", "quic", "fakedns", "fakedns+others"] }
            },
            "metadataOnly": { "type": "boolean", "default": false },
            "domainsExcluded": { "type": "array", "items": { "type": "string" } },
            "routeOnly": { "type": "boolean", "default": false }
          }
        },
        "allocate": {
          "type": "object",
          "properties": {
            "strategy": { "type": "string", "enum": ["always", "random"] },
            "refresh": { "type": "integer" },
            "concurrency": { "type": "integer" }
          }
        }
      },
      "required": ["port", "protocol"]
    },

    "outbound": {
      "type": "object",
      "description": "Исходящее подключение",
      "properties": {
        "sendThrough": { "type": "string", "default": "0.0.0.0", "description": "IP для отправки" },
        "protocol": {
          "type": "string",
          "enum": ["blackhole", "dns", "freedom", "http", "socks", "vmess", "vless", "shadowsocks", "trojan", "wireguard", "loopback"],
          "description": "Протокол"
        },
        "settings": {
          "type": "object",
          "description": "Настройки протокола (зависят от protocol)"
        },
        "tag": { "type": "string", "description": "Уникальный тег" },
        "streamSettings": { "$ref": "#/definitions/streamSettings" },
        "proxySettings": {
          "type": "object",
          "properties": {
            "tag": { "type": "string", "description": "Тег outbound-прокси" },
            "transportLayer": { "type": "boolean", "default": false }
          }
        },
        "mux": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "concurrency": { "type": "integer", "default": 8, "minimum": -1, "maximum": 1024 },
            "xudpConcurrency": { "type": "integer", "default": 0 },
            "xudpProxyUDP443": { "type": "string", "enum": ["reject", "allow", "skip"] }
          }
        },
        "domainStrategy": { "type": "string", "enum": ["AsIs", "UseIP", "UseIPv4", "UseIPv6", "ForceIP", "ForceIPv4", "ForceIPv6"] }
      },
      "required": ["protocol"]
    }
  }
}
